search_pod_across_all_dbs() {
    local search_term="$1"

    local unique_hosts=($(get_all_unique_hosts))
    local total_hosts=${#unique_hosts[@]}
    local current=0

    # Track summary statistics
    declare -a hosts_with_results
    declare -a hosts_without_results
    declare -a hosts_failed

    for host in "${unique_hosts[@]}"; do
        current=$((current + 1))
        echo ""
        echo "###############################################################################"
        echo "# SEARCHING FOR: $search_term ON HOST: $host [$current/$total_hosts]"
        echo "# DB Files: $(get_db_files_for_host "$host")"
        echo "###############################################################################"

        # Get database files for this host
        local nb_file=$(get_database_file_for_host "$host" "n" || echo "")
        local sb_file=$(get_database_file_for_host "$host" "s" || echo "")

        if [ -z "$nb_file" ] && [ -z "$sb_file" ]; then
            echo "WARNING: No databases found for host $host"
            continue
        fi

        # Start the database pair for this host
        if ! start_database_pair "$host" "$nb_file" "$sb_file"; then
            echo "ERROR: Failed to start databases for host $host, skipping..."
            hosts_failed+=("$host")
            clean_up_current_containers
            continue
        fi

        # Get the container names
        local safe_host=$(sanitize_hostname "$host")
        local nb_container=""
        local sb_container=""
        [ -n "$nb_file" ] && nb_container="${CONTAINER_NAME_PREFIX}_nb_${safe_host}"
        [ -n "$sb_file" ] && sb_container="${CONTAINER_NAME_PREFIX}_sb_${safe_host}"

        # Track if we found any results on this host
        local found_results=false

        if [ -n "$nb_container" ]; then
            echo ""
            echo "=== Logical Switch Ports ==="
            show_command "ovn-nbctl --no-leader-only find logical_switch_port external_ids:pod=true | grep -i -B10 -A15 $search_term"
            local lsps=$(run_check_on_container "$nb_container" "ovn-nbctl --no-leader-only find logical_switch_port external_ids:pod=true" | grep -i -B10 -A15 "$search_term" || true)

            if [ -n "$lsps" ]; then
                echo "$lsps"
                found_results=true
            else
                echo "No matching pods found"
            fi
        fi

        if [ -n "$sb_container" ]; then
            echo ""
            echo "=== Port Bindings ==="
            show_command "ovn-sbctl --no-leader-only find port_binding | grep -i -B5 -A10 $search_term"
            local pbs=$(run_check_on_container "$sb_container" "ovn-sbctl --no-leader-only find port_binding" | grep -i -B5 -A10 "$search_term" || true)
            if [ -n "$pbs" ]; then
                echo "$pbs"
                found_results=true
            else
                echo "No matching port bindings found"
            fi
        fi

        if [ -n "$nb_container" ]; then
            echo ""
            echo "=== NAT Rules ==="
            show_command "ovn-nbctl --no-leader-only list NAT | grep -i -B5 -A5 $search_term"
            local nats=$(run_check_on_container "$nb_container" "ovn-nbctl --no-leader-only list NAT" | grep -i -B5 -A5 "$search_term" || true)
            if [ -n "$nats" ]; then
                echo "$nats"
                found_results=true
            else
                echo "No matching NAT rules found"
            fi

            echo ""
            echo "=== ACLs ==="
            show_command "ovn-nbctl --no-leader-only find ACL | grep -i -B5 -A5 $search_term"
            local acls=$(run_check_on_container "$nb_container" "ovn-nbctl --no-leader-only find ACL" | grep -i -B5 -A5 "$search_term" || true)
            if [ -n "$acls" ]; then
                echo "$acls"
                found_results=true
            else
                echo "No matching ACLs found"
            fi

            echo ""
            echo "=== Port Groups ==="
            show_command "ovn-nbctl --no-leader-only find port_group | grep -i -B5 -A10 $search_term"
            local pgs=$(run_check_on_container "$nb_container" "ovn-nbctl --no-leader-only find port_group" | grep -i -B5 -A10 "$search_term" || true)
            if [ -n "$pgs" ]; then
                echo "$pgs"
                found_results=true
            else
                echo "No matching port groups found"
            fi

            echo ""
            echo "=== Load Balancers ==="
            show_command "ovn-nbctl --no-leader-only find load_balancer | grep -i -B5 -A10 $search_term"
            local lbs=$(run_check_on_container "$nb_container" "ovn-nbctl --no-leader-only find load_balancer" | grep -i -B5 -A10 "$search_term" || true)
            if [ -n "$lbs" ]; then
                echo "$lbs"
                found_results=true
            else
                echo "No matching load balancers found"
            fi
        fi

        # Track summary
        if [ "$found_results" = true ]; then
            hosts_with_results+=("$host")
        else
            hosts_without_results+=("$host")
        fi

        # Clean up this pair before moving to the next
        echo ""
        echo "Cleaning up containers for $host..."
        clean_up_current_containers
    done

    echo ""
    echo "###############################################################################"
    echo "# SEARCH COMPLETE ACROSS ALL DATABASES"
    echo "###############################################################################"
    echo ""
    echo "=== SEARCH SUMMARY ==="
    echo "Total hosts scanned: $total_hosts"
    echo ""
    echo "Hosts with matching results: ${#hosts_with_results[@]}"
    if [ ${#hosts_with_results[@]} -gt 0 ]; then
        for host in "${hosts_with_results[@]}"; do
            echo "  - $host ($(get_db_files_for_host "$host"))"
        done
    fi
    echo ""
    echo "Hosts without matching results: ${#hosts_without_results[@]}"
    if [ ${#hosts_without_results[@]} -gt 0 ]; then
        for host in "${hosts_without_results[@]}"; do
            echo "  - $host ($(get_db_files_for_host "$host"))"
        done
    fi
    if [ ${#hosts_failed[@]} -gt 0 ]; then
        echo ""
        echo "Hosts that failed to start: ${#hosts_failed[@]}"
        for host in "${hosts_failed[@]}"; do
            echo "  - $host ($(get_db_files_for_host "$host"))"
        done
    fi
    echo ""
}

resolve_pod_name_to_ip_all() {
    local pod_identifier="$1"
    local pod_ip=""
    local pod_name=""

    # Check if it's an IP address
    if [[ "$pod_identifier" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "$pod_identifier:"
        return 0
    fi

    # Try to resolve from any northbound database
    pod_name="$pod_identifier"
    echo "Resolving pod name: $pod_name across all databases..." >&2

    local unique_hosts=($(get_all_unique_hosts))

    for host in "${unique_hosts[@]}"; do
        local nb_file=$(get_database_file_for_host "$host" "n" || echo "")

        if [ -z "$nb_file" ]; then
            continue
        fi

        # Start just the northbound database temporarily for resolution
        local safe_host=$(sanitize_hostname "$host")
        local nb_container="${CONTAINER_NAME_PREFIX}_nb_${safe_host}_resolve"
        echo -n "  Checking $host... " >&2

        start_ovn_db "$nb_container" "$nb_file" "n" >/dev/null 2>&1

        if check_ovn_db "$nb_container" "n"; then
            local search_result=$(run_check_on_container "$nb_container" "ovn-nbctl --no-leader-only find logical_switch_port external_ids:pod=true" | grep -B20 -A5 "$pod_name" || true)

            if [ -n "$search_result" ]; then
                pod_ip=$(echo "$search_result" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -1)

                if [ -n "$pod_ip" ]; then
                    echo "found!" >&2
                    echo "Resolved $pod_name to IP: $pod_ip on $host" >&2

                    # Clean up the temporary container
                    $CONTAINER_ENGINE stop "$nb_container" 2>/dev/null || true
                    $CONTAINER_ENGINE rm "$nb_container" 2>/dev/null || true
                    CURRENT_NB_CONTAINER=""

                    echo "$pod_ip:$pod_name"
                    return 0
                fi
            fi
            echo "not found" >&2
        else
            echo "failed to start" >&2
        fi

        # Clean up this temporary container
        $CONTAINER_ENGINE stop "$nb_container" 2>/dev/null || true
        $CONTAINER_ENGINE rm "$nb_container" 2>/dev/null || true
        CURRENT_NB_CONTAINER=""
    done

    echo "ERROR: Could not resolve pod name '$pod_name' to an IP address" >&2
    return 1
}

main() {
    # Parse optional --verbose flag
    if [ "${1:-}" = "--verbose" ]; then
        VERBOSE=true
        shift
        log_verbose "Verbose mode enabled"
    fi

    if [ $# -lt 2 ]; then
        echo "ERROR: Insufficient arguments" >&2
        help
        exit 1
    fi

    DB_DIR=$(get_full_path "$1")
    POD_IDENTIFIER="$2"

    # Validate that DB_DIR exists and is a directory
    if [ ! -d "$DB_DIR" ]; then
        echo "ERROR: '$DB_DIR' is not a directory or does not exist" >&2
        exit 1
    fi

    # Check if this is a search operation
    SEARCH_MODE=false
    if [ "$POD_IDENTIFIER" = "--search" ]; then
        SEARCH_MODE=true
        if [ $# -lt 3 ]; then
            echo "ERROR: --search requires a search term" >&2
            help
            exit 1
        fi
        SEARCH_TERM="$3"
        CONTAINER_ENGINE="${4:-docker}"
    else
        CONTAINER_ENGINE="${3:-docker}"
    fi

    # Validate dependencies
    if ! command -v jq &> /dev/null; then
        echo "ERROR: jq is not installed. Please install jq to use this script." >&2
        exit 1
    fi

    if ! command -v "$CONTAINER_ENGINE" &> /dev/null; then
        echo "ERROR: Container engine '$CONTAINER_ENGINE' is not installed or not in PATH" >&2
        exit 1
    fi

    # Verify container engine is working
    if ! $CONTAINER_ENGINE ps >/dev/null 2>&1; then
        echo "ERROR: Container engine '$CONTAINER_ENGINE' is not working properly" >&2
        echo "       Make sure the daemon is running and you have permissions" >&2
        exit 1
    fi

    # Setup cleanup trap
    trap clean_up_all EXIT INT TERM

    # Scan and organize databases (don't start them yet)
    scan_and_organize_databases "$DB_DIR"

    # Execute search mode or flow analysis
    if [ "$SEARCH_MODE" = true ]; then
        search_pod_across_all_dbs "$SEARCH_TERM"
    else
        # Resolve pod name to IP if needed
        resolved=$(resolve_pod_name_to_ip_all "$POD_IDENTIFIER")
        if [ $? -ne 0 ]; then
            echo "ERROR: Failed to resolve pod identifier" >&2
            exit 1
        fi

        POD_IP=$(echo "$resolved" | cut -d':' -f1)
        POD_NAME=$(echo "$resolved" | cut -d':' -f2)

        # Validate IP address format
        if ! [[ "$POD_IP" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            echo "ERROR: Invalid IP address format: $POD_IP" >&2
            exit 1
        fi

        # Perform flow analysis across all databases (one pair at a time)
        check_pod_ip_across_all_dbs "$POD_IP" "$POD_NAME"
    fi

    echo ""
    echo "Analysis complete! All containers have been cleaned up."
}

case "${1:-}" in
  description) description ;;
  -h|--help) help ;;
  *) main "$@" ;;
esac
